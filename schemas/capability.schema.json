{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ActiveInAI/PanAEC-Engine/schemas/capability.schema.json",
  "title": "PanAEC Engine Capability Registry",
  "type": "object",
  "required": ["engine", "capabilities"],
  "properties": {
    "engine": {
      "type": "object",
      "required": ["name", "spdxLicense", "copyright", "copyrightOwner", "repository"],
      "properties": {
        "name": { "const": "PanAEC Engine" },
        "spdxLicense": { "const": "AGPL-3.0-only" },
        "copyright": { "type": "string", "minLength": 1 },
        "copyrightOwner": { "const": "潘永胜" },
        "repository": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "formats", "boundary", "semanticTruthRequired"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "label": { "type": "string", "minLength": 1 },
          "formats": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "boundary": { "type": "string", "minLength": 1 },
          "semanticTruthRequired": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

